  {id:'R16_5',h:'Costa de Marfil',a:'Noruega',label:'Jun 30 · 12:00',lock:'2026-06-30T11:00'},
  {id:'R16_6',h:'Francia',a:'Suecia',label:'Jun 30 · 16:00',lock:'2026-06-30T15:00'},
  {id:'R16_7',h:'México',a:'Ecuador',label:'Jun 30 · 20:00',lock:'2026-06-30T19:00'},
  {id:'R16_8',h:'Inglaterra',a:'RD Congo',label:'Jul 1 · 11:00',lock:'2026-07-01T10:00'},
