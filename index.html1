const MATCHES = [
  {id:'QF1',h:'Canadá',a:'Marruecos',label:'Jul 4 · 12:00',lock:'2026-07-04T11:45'},
  {id:'QF2',h:'Paraguay',a:'Francia',label:'Jul 4 · 16:00',lock:'2026-07-04T15:45'},
  {id:'QF3',h:'Brasil',a:'Noruega',label:'Jul 5 · 15:00',lock:'2026-07-05T14:45'},
  {id:'QF4',h:'México',a:'Inglaterra',label:'Jul 5 · 19:00',lock:'2026-07-05T18:45'},
  {id:'QF5',h:'Portugal',a:'España',label:'Jul 6 · 14:00',lock:'2026-07-06T13:45'},
  {id:'QF6',h:'Est. Unidos',a:'Bélgica',label:'Jul 6 · 19:00',lock:'2026-07-06T18:45'},
  {id:'QF7',h:'Argentina',a:'Egipto',label:'Jul 7 · 15:00',lock:'2026-07-07T14:45'},
  {id:'QF8',h:'Suiza',a:'Colombia',label:'Jul 7 · 15:00',lock:'2026-07-07T14:45'},
];

let currentUser = null, adminOk = false, admin2Ok = false, localPron = {}, results = {}, allParticipants = {}, dirty = false, groupStagePts = {};

function getWinner(h,a){ return h>a?'h':a>h?'a':'e'; }
function isLocked(m){ return new Date() >= new Date(m.lock+':00-05:00'); }
function timeUntilLock(m){
  const diff = new Date(m.lock+':00-05:00') - new Date();
  if(diff<=0) return null;
  const h=Math.floor(diff/3600000), min=Math.floor((diff%3600000)/60000);
  if(h>24) return null;
  return h>0?`Cierra en ${h}h ${min}m`:min>0?`Cierra en ${min}m`:`¡Cierra ya!`;
}

function fbGet(path){ return db.ref(path).once('value').then(s=>s.exists()?s.val():null); }
function fbSet(path,val){ return db.ref(path).set(val); }
function fbListen(path,cb){ db.ref(path).on('value',s=>cb(s.exists()?s.val():{})); }

function oldGetWinner(h,a){ return h>a?'h':a>h?'a':'e'; }

function calcOldPts(pron, oldResults){
  let pts=0;
  for(const m of OLD_MATCHES){
    const v=pron[m.id], r=oldResults[m.id];
    if(!v||!r) continue;
    if(v.h===r.h && v.a===r.a) pts+=3;
    else if(oldGetWinner(v.h,v.a)===oldGetWinner(r.h,r.a)) pts+=2;
  }
  return pts;
}

function calcR16Pts(pron, r16Results){
  let pts=0;
  for(const m of OLD_MATCHES_R16){
    const v=pron[m.id], r=r16Results[m.id];
    if(!v||!r) continue;
    const out = scoreOutcome(v,r);
    pts += out.pts;
  }
  return pts;
}

async function migrateToRoundOf16(){
  const migrated = await fbGet('migrated_octavos');
  if(migrated) {
    // Ya migrado a octavos: carga los puntos históricos acumulados
    groupStagePts = await fbGet('all_historic_points') || {};
    // Reparación: si participants quedó vacío, restaurar desde respaldo
    const current = await fbGet('participants') || {};
    if(Object.keys(current).length === 0){
      const backup = await fbGet('participants_fase_grupos') || {};
      if(Object.keys(backup).length > 0){
        const restored = {};
        for(const name of Object.keys(backup)) restored[name] = { _joined: true };
        await fbSet('participants', restored);
      }
    }
    return;
  }
  // Viene de migración de 16avos o directamente de fase de grupos
  const migratedR16 = await fbGet('migrated_r16');
  const groupPts = await fbGet('group_stage_points') || {};
  const r16Results = await fbGet('results') || {};
  const parts = await fbGet('participants') || {};

  // Calcula puntos de 16avos (sistema nuevo 3/2/1) para cada persona
  const allHistoric = {};
  for(const name of Object.keys(parts)){
    const r16Pts = calcR16Pts(parts[name] || {}, r16Results);
    allHistoric[name] = (groupPts[name] || 0) + r16Pts;
  }

  await fbSet('all_historic_points', allHistoric);
  await fbSet('results_16avos', r16Results);
  await fbSet('participants_16avos', parts);
  await fbSet('results', {});
  const cleanParts = {};
  for(const name of Object.keys(parts)) cleanParts[name] = { _joined: true };
  await fbSet('participants', cleanParts);
  await fbSet('migrated_octavos', true);
  groupStagePts = allHistoric;
  return;

}

async function init(){
  await migrateToRoundOf16();
  const saved = localStorage.getItem('polla26_user');
  if(saved){ currentUser=saved; setUserPill(saved); localPron=await fbGet('participants/'+saved)||{}; }
  results = await fbGet('results')||{};
  allParticipants = await fbGet('participants')||{};
  renderReg(); renderRanking(); renderAdminLogin();
  fbListen('results',val=>{ results=val||{}; if(document.getElementById('p-ranking').classList.contains('active')) renderRanking(); if(document.getElementById('p-fixture').classList.contains('active')&&currentUser&&!dirty) renderFixture(); if(document.getElementById('p-envivo').classList.contains('active')) renderEnVivo(); });
  fbListen('participants',val=>{ allParticipants=val||{}; if(document.getElementById('p-ranking').classList.contains('active')) renderRanking(); if(document.getElementById('p-envivo').classList.contains('active')) renderEnVivo(); });
  setInterval(()=>{ if(document.getElementById('p-fixture').classList.contains('active')&&currentUser&&!dirty) renderFixture(); },60000);
}

function goTab(t){
  document.querySelectorAll('.tab').forEach((b,i)=>b.classList.toggle('active',['inicio','fixture','envivo','ranking','admin'][i]===t));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('p-'+t).classList.add('active');
  document.getElementById('sfloat').style.display=(t==='fixture'&&currentUser)?'block':'none';
  if(t==='fixture'&&currentUser) renderFixture();
  if(t==='envivo') renderEnVivo();
  if(t==='ranking') renderRanking();
  if(t==='admin'&&(adminOk||admin2Ok)) { if(adminOk) renderAdminPanel(); else renderParticipantPanel(); }
}

function setUserPill(name){ document.getElementById('udot').style.background='var(--accent)'; document.getElementById('uname').textContent=name; }

function logoutUser(){
  if(!currentUser) return;
  currentUser=null; localPron={};
  localStorage.removeItem('polla26_user');
  document.getElementById('udot').style.background='var(--text3)';
  document.getElementById('uname').textContent='Entrar';
  document.getElementById('sfloat').style.display='none';
  renderReg(); goTab('inicio');
}

function renderReg(){
  const el=document.getElementById('reg');
  if(currentUser){
    const n=countPron(localPron);
    el.innerHTML=`<div style="display:flex;align-items:center;gap:12px;margin-bottom:12px"><div style="width:42px;height:42px;background:var(--accent-dim);border:1px solid var(--accent-mid);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:700;color:var(--accent)">${currentUser[0].toUpperCase()}</div><div><div style="font-size:15px;font-weight:700">${currentUser}</div><div style="font-size:11px;color:var(--text3)">${n} de ${MATCHES.length} partidos pronosticados</div></div></div><div class="prog-wrap"><div class="prog-bar" style="width:${Math.round(n/MATCHES.length*100)}%"></div></div><button class="btn-p" onclick="goTab('fixture')">✏️ Ir a Pronósticos</button><button class="btn-s" onclick="logoutUser()">Cambiar de usuario</button><div class="banner" style="margin-top:14px">⏰ Pronósticos bloqueados <span>15 minutos antes</span> de cada partido · 🎯 3pts · 🏆 2pts · 🥈 +1pt</div>`;
  } else {
    el.innerHTML=`<div class="banner">⚽ Octavos de Final · 16 partidos · <span>3pts exacto · 2pts ganador · +1pt extra</span></div><div class="card"><h2>Únete a la polla</h2><p>Escribe tu nombre. Si ya participaste antes, escribe el mismo nombre para continuar.</p><div class="field"><label>Tu nombre</label><input id="rname" placeholder="Ej: Lázaro" onkeydown="if(event.key==='Enter')doReg()"/></div><div id="rmsg"></div><button class="btn-p" onclick="doReg()">Entrar y pronosticar →</button></div>`;
  }
}

function countPron(pron){
  return Object.keys(pron||{}).filter(k=>k!=='_joined').length;
}

function normalizeName(raw){
  return raw.trim().replace(/\s+/g,' ').replace(/\b\w/g, c=>c.toUpperCase());
}

async function doReg(){
  const raw=document.getElementById('rname')?.value || '';
  const name=normalizeName(raw);
  if(!name){showMsg('rmsg','err','Escribe tu nombre');return;}
  showMsg('rmsg','ok','Conectando...');
  const existing=await fbGet('participants/'+name);
  localPron=existing||{};
  if(!existing) await fbSet('participants/'+name,{_joined:true});
  currentUser=name;
  localStorage.setItem('polla26_user',name);
  setUserPill(name);
  setTimeout(()=>{renderReg();goTab('fixture');},500);
}

function getLoserGoals(h,a){ return Math.min(h,a); }

function scoreOutcome(v,r){
  if(!v||!r) return {pts:0, type:'none'};
  // 1. Marcador exacto
  if(v.h===r.h && v.a===r.a) return {pts:3, type:'exact'};
  const sameWinner = getWinner(v.h,v.a)===getWinner(r.h,r.a);
  // 2. Acertó el ganador (pero no el marcador exacto)
  if(sameWinner) return {pts:2, type:'winner'};
  // 3. No acertó el ganador, pero sí los goles del perdedor real
  const loserOk = getLoserGoals(v.h,v.a)===getLoserGoals(r.h,r.a);
  if(loserOk) return {pts:1, type:'loser'};
  // 4. No acertó nada
  return {pts:0, type:'none'};
}

function renderFixture(){
  if(!currentUser) return;
  const pron=localPron||{};
  let html=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:6px"><div style="font-size:12px;color:var(--text2)">Completados: <strong style="color:var(--accent)">${countPron(pron)}/${MATCHES.length}</strong></div><div style="font-size:11px;color:var(--text3)">🔒 Bloqueo 15min antes · 🎯 3pts · 🏆 2pts · 🥈 1pt</div></div>`;
  html+=`<div class="g-hdr"><div class="g-lbl">Octavos de Final</div><div class="g-line"></div></div>`;
  for(const m of MATCHES){
    const v=pron[m.id], r=results[m.id];
    const timeLocked=isLocked(m), adminLocked=r!==undefined, locked=timeLocked||adminLocked;
    const out = adminLocked && v ? scoreOutcome(v,r) : {pts:0,type:'none'};
    const countdown=timeUntilLock(m);
    let meta=m.label, mc='';
    if(adminLocked && v){
      if(out.type==='exact'){meta=`✓ EXACTO +3pts — ${r.h}–${r.a}`;mc='ex';}
      else if(out.type==='winner'){meta=`🏆 Ganador +2pts — Res: ${r.h}–${r.a}`;mc='win';}
      else if(out.type==='loser'){meta=`🥈 Goles del perdedor +1pt — Res: ${r.h}–${r.a}`;mc='loser';}
      else {meta=`${m.label} · Res: ${r.h}–${r.a}`;}
    }
    else if(adminLocked&&r){meta=`${m.label} · Res: ${r.h}–${r.a}`;}
    else if(timeLocked){meta=`${m.label} · 🔒 Cerrado`;mc='closed';}
    else if(countdown){meta=`${m.label} · ⏰ ${countdown}`;}
    html+=`<div class="mc ${v?'filled':''} ${out.type==='exact'?'exact':''} ${out.type==='winner'?'winner':''} ${out.type==='loser'?'loserpts':''} ${locked?'locked':''}"><div class="mi"><div class="tn h">${m.h}</div><input class="si" type="number" min="0" max="30" placeholder="?" id="fh-${m.id}" value="${v!==undefined?v.h:''}" ${locked?'disabled':''} oninput="dirty=true"><div class="vs">–</div><input class="si" type="number" min="0" max="30" placeholder="?" id="fa-${m.id}" value="${v!==undefined?v.a:''}" ${locked?'disabled':''} oninput="dirty=true"><div class="tn a">${m.a}</div></div><div class="mm ${mc}">${meta}</div></div>`;
  }
  document.getElementById('fix').innerHTML=html;
}

async function saveAll(){
  if(!currentUser) return;
  const btn=document.getElementById('sfloat');
  btn.textContent='⏳ Guardando...';
  // Recarga el estado más reciente de Firebase para no pisar datos guardados desde otro dispositivo/pestaña
  const fresh = await fbGet('participants/'+currentUser) || {};
  const updates = {};
  for(const m of MATCHES){
    if(isLocked(m)) continue;
    const h=document.getElementById('fh-'+m.id), a=document.getElementById('fa-'+m.id);
    if(h&&a&&h.value!==''&&a.value!==''){
      const val = {h:parseInt(h.value), a:parseInt(a.value)};
      updates[m.id] = val;
      fresh[m.id] = val;
    }
  }
  // Escribe solo los campos de partidos (update), nunca reemplaza el nodo completo del usuario
  const ref = {};
  for(const [mid,val] of Object.entries(updates)){
    ref['participants/'+currentUser+'/'+mid] = val;
  }
  if(Object.keys(ref).length) await db.ref().update(ref);
  localPron = fresh;
  dirty=false;
  btn.textContent='✓ Guardado';
  setTimeout(()=>{btn.textContent='💾 Guardar';renderFixture();},1500);
}

function calcPts(name){
  const pron=allParticipants[name]||{};
  let pts=0,exact=0,winner=0,loserBonus=0,total=countPron(pron);
  for(const m of MATCHES){
    const v=pron[m.id],r=results[m.id];
    if(!v||!r) continue;
    const out = scoreOutcome(v,r);
    pts += out.pts;
    if(out.type==='exact') exact++;
    else if(out.type==='winner') winner++;
    else if(out.type==='loser') loserBonus++;
  }
  const histPts = groupStagePts[name] || 0;
  return{pts:pts+histPts, exact, winner, loserBonus, total, histPts};
}

function getCurrentMatch(){
  const now = new Date();
  // Partido en curso: ya pasó su locktime pero no han pasado 3h desde el kickoff
  for(const m of MATCHES){
    const kick = new Date(m.lock+':00-05:00');
    kick.setMinutes(kick.getMinutes()+15); // kickoff = lock + 15min
    const end = new Date(kick.getTime()+3*3600000);
    if(now>=kick && now<=end) return {m, state:'live'};
  }
  // Si no hay partido en curso, el próximo que empiece
  for(const m of MATCHES){
    const kick = new Date(m.lock+':00-05:00');
    kick.setMinutes(kick.getMinutes()+15);
    if(now<kick) return {m, state:'upcoming'};
  }
  // Si ya terminaron todos
  return {m: MATCHES[MATCHES.length-1], state:'finished'};
}

let evMatchId = null;

function renderEnVivo(){
  const el = document.getElementById('envivo');
  const {m: autoMatch, state} = getCurrentMatch();
  if(!evMatchId) evMatchId = autoMatch.id;
  const m = MATCHES.find(x=>x.id===evMatchId) || autoMatch;
  const r = results[m.id];
  const names = Object.keys(allParticipants).sort();

  // Nav: partidos bloqueados (ya cerraron pronósticos)
  const locked = MATCHES.filter(x=>isLocked(x));
  const navHtml = locked.length ? `<div class="ev-nav">${locked.map(lm=>`<button class="${lm.id===m.id?'active':''}" onclick="evMatchId='${lm.id}';renderEnVivo()">${lm.h.split(' ')[0]} vs ${lm.a.split(' ')[0]}<br><span style="font-size:10px;font-weight:400">${lm.label.split('·')[0].trim()}</span></button>`).join('')}</div>` : '';

  // Resultado
  const resHtml = r!==undefined
    ? `<div class="ev-result">${r.h} – ${r.a}</div>`
    : `<div style="font-size:13px;color:var(--text3);text-align:center;margin-bottom:12px">${state==='live'?'⚽ En curso — resultado pendiente':'⏳ Aún no hay resultado'}</div>`;

  // Tabla de pronósticos
  const rowsHtml = names.map(n=>{
    const v = allParticipants[n]?.[m.id];
    let scoreClass='pending', icon='', pts='';
    if(v && r!==undefined){
      const out = scoreOutcome(v,r);
      pts = out.pts ? '+'+out.pts : '0';
      if(out.type==='exact'){scoreClass='exact';icon=' ✓';}
      else if(out.type==='winner'){scoreClass='winner';icon=' ▲';}
      else if(out.type==='loser'){scoreClass='loser';icon=' ◆';}
      else{scoreClass='wrong';icon=' ✗';}
    }
    const scoreStr = v!==undefined ? `${v.h}–${v.a}${icon}` : '—';
    const colorVar = scoreClass==='exact'?'accent2':scoreClass==='winner'?'gold':scoreClass==='loser'?'accent2':'text3';
    return `<tr>
      <td style="font-weight:600">${n}${n===currentUser?' <span style="font-size:10px;color:var(--accent)">(tú)</span>':''}</td>
      <td class="ev-score ${scoreClass}">${scoreStr}</td>
      <td style="text-align:right;font-size:12px;color:var(--${colorVar})">${pts}</td>
    </tr>`;
  }).join('');

  el.innerHTML = `
    ${navHtml}
    <div class="ev-match">
      <div class="ev-teams">${m.h} vs ${m.a}</div>
      <div class="ev-date">${m.label}</div>
      ${resHtml}
      <table class="ev-table">
        <thead><tr><th>Participante</th><th style="text-align:center">Pronóstico</th><th style="text-align:right">Pts</th></tr></thead>
        <tbody>${rowsHtml}</tbody>
      </table>
    </div>`;
}

function renderRanking(){
  const el=document.getElementById('rank');
  const names=Object.keys(allParticipants);
  const rc=Object.keys(results).length;
  const now=new Date().toLocaleString('es-CO',{hour:'2-digit',minute:'2-digit',day:'numeric',month:'short'});
  if(!names.length){el.innerHTML='<p style="color:var(--text2);padding:20px 0">Nadie se ha registrado aún.</p>';return;}
  const ranked=names.map(n=>({n,...calcPts(n)})).sort((a,b)=>b.pts-a.pts||b.exact-a.exact||b.winner-a.winner);
  const pos=i=>['🥇','🥈','🥉'][i]||(i+1)+'°';
  el.innerHTML=`<div class="lupd">${now} <button class="rbtn" onclick="renderRanking()">↺ Actualizar</button></div><div class="stat-row"><div class="sbox"><div class="n">${names.length}</div><div class="l">Jugadores</div></div><div class="sbox"><div class="n">${rc}</div><div class="l">Jugados</div></div><div class="sbox"><div class="n" style="font-size:16px">3/2/1</div><div class="l">Exacto/Gan/Perd</div></div></div><div style="font-size:11px;color:var(--text3);margin-bottom:10px">🎯 Exacto=3pts &nbsp;·&nbsp; 🏆 Ganador=2pts &nbsp;·&nbsp; 🥈 Solo goles del perdedor=1pt</div><table class="rtable"><thead><tr><th>#</th><th>Nombre</th><th>🎯</th><th>🏆</th><th>🥈</th><th style="text-align:right">Pts</th></tr></thead><tbody>${ranked.map((r,i)=>`<tr ${r.n===currentUser?'class="me"':''}><td>${pos(i)}</td><td style="font-weight:600">${r.n}${r.n===currentUser?' <span style="font-size:10px;color:var(--accent)">(tú)</span>':''}</td><td style="color:var(--accent2)">${r.exact}</td><td style="color:var(--gold)">${r.winner}</td><td style="color:var(--accent2)">${r.loserBonus}</td><td class="pts">${r.pts}</td></tr>`).join('')}</tbody></table>`;
}

function renderAdminLogin(){
  document.getElementById('adm').innerHTML=`<div class="card" style="max-width:360px"><h2>Administrador</h2><p>Ingresa tu contraseña para acceder al panel.</p><div class="field"><label>Contraseña</label><input type="password" id="apass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doAdminLogin()"/></div><div id="amsg"></div><button class="btn-p" onclick="doAdminLogin()">Entrar</button></div>`;
}

async function doAdminLogin(){
  const p=document.getElementById('apass')?.value;
  if(p===ADMIN_PASS){
    adminOk=true;
    oldResultsCache = await fbGet('results_fase_grupos') || {};
    renderAdminPanel();
  }
  else if(p===ADMIN_PASS2){admin2Ok=true;renderParticipantPanel();}
  else showMsg('amsg','err','Contraseña incorrecta');
}

async function renderParticipantPanel(){
  allParticipants = await fbGet('participants')||{};
  const names = Object.keys(allParticipants).sort();
  const el = document.getElementById('adm');
  el.innerHTML=`<div class="ahdr">
    <span style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--red)">Gestión de Participantes</span>
  </div>
  <div style="font-size:12px;color:var(--text2);margin-bottom:14px">${names.length} participantes registrados · Puedes eliminar duplicados o errores</div>
  <div id="part-list">
    ${names.map(n=>`
      <div style="display:flex;align-items:center;justify-content:space-between;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;margin-bottom:6px;">
        <div>
          <div style="font-size:13px;font-weight:600">${n}</div>
          <div style="font-size:11px;color:var(--text3)">${countPron(allParticipants[n])} pronósticos</div>
        </div>
        <button onclick="deleteParticipant('${n}')" style="background:#E8404018;border:1px solid #E8404055;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;color:var(--red);cursor:pointer;">🗑️ Eliminar</button>
      </div>`).join('')}
  </div>`;
}

async function deleteParticipant(name){
  if(!confirm(`¿Eliminar a "${name}"? Esta acción no se puede deshacer.`)) return;
  await db.ref('participants/'+name).remove();
  allParticipants = await fbGet('participants')||{};
  renderParticipantPanel();
  renderRanking();
}

let adminSectionOpen = { r16: true, grupos: false };
let oldResultsCache = {};

function toggleAdminSection(key){
  adminSectionOpen[key] = !adminSectionOpen[key];
  renderAdminPanel();
}

function renderAdminPanel(){
  const el=document.getElementById('adm');
  const oldDone = Object.keys(oldResultsCache||{}).length;
  let html=`<div class="ahdr"><span style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--gold)">Panel Admin</span><button class="savebtn" onclick="saveResults()">Guardar todo →</button></div>`;

  // Sección: Dieciseisavos (fase actual)
  html+=`<div class="phase-hdr" onclick="toggleAdminSection('r16')">
    <span>⚽ Octavos de Final <span style="color:var(--text3);font-weight:400">(${Object.keys(results).length}/${MATCHES.length})</span></span>
    <span class="chev">${adminSectionOpen.r16?'▾':'▸'}</span>
  </div>`;
  if(adminSectionOpen.r16){
    for(const m of MATCHES){
      const r=results[m.id]||{};
      html+=`<div class="am ${r.h!==undefined?'done':''}"><div class="ami"><div class="tn h" style="font-size:11px">${m.h}</div><input class="ai" type="number" min="0" max="30" placeholder="?" id="rh-${m.id}" value="${r.h!==undefined?r.h:''}"><div class="vs" style="font-size:11px;color:var(--text3)">–</div><input class="ai" type="number" min="0" max="30" placeholder="?" id="ra-${m.id}" value="${r.a!==undefined?r.a:''}"><div class="tn a" style="font-size:11px">${m.a}</div></div><div class="mm">${m.label}</div></div>`;
    }
  }

  // Sección: Fase de grupos (histórica, editable para correcciones)
  html+=`<div class="phase-hdr" onclick="toggleAdminSection('grupos')" style="margin-top:14px">
    <span>🏆 Fase de Grupos <span style="color:var(--text3);font-weight:400">(${oldDone}/${OLD_MATCHES.length}) · editable para corregir resultados pasados</span></span>
    <span class="chev">${adminSectionOpen.grupos?'▾':'▸'}</span>
  </div>`;
  if(adminSectionOpen.grupos){
    html+=`<div style="font-size:11px;color:var(--text3);margin-bottom:8px">Si corriges o agregas un resultado aquí, los puntos acumulados de todos se recalculan automáticamente al guardar.</div>`;
    const groupsSet = ['A','B','C','D','E','F','G','H','I','J','K','L'];
    for(const g of groupsSet){
      html+=`<div class="ag" style="font-size:13px">Grupo ${g}</div>`;
      for(const m of OLD_MATCHES.filter(x=>x.g===g)){
        const r=(oldResultsCache||{})[m.id]||{};
        html+=`<div class="am ${r.h!==undefined?'done':''}"><div class="ami"><div class="tn h" style="font-size:11px">${m.h}</div><input class="ai" type="number" min="0" max="30" placeholder="?" id="orh-${m.id}" value="${r.h!==undefined?r.h:''}"><div class="vs" style="font-size:11px;color:var(--text3)">–</div><input class="ai" type="number" min="0" max="30" placeholder="?" id="ora-${m.id}" value="${r.a!==undefined?r.a:''}"><div class="tn a" style="font-size:11px">${m.a}</div></div><div class="mm">${m.label}</div></div>`;
      }
    }
  }

  html+=`<div style="margin-top:14px"><button class="savebtn" style="width:100%" onclick="saveResults()">Guardar todo y recalcular</button></div>`;
  el.innerHTML=html;
}

async function saveResults(){
  document.querySelectorAll('.savebtn').forEach(b=>b.textContent='Guardando...');

  // Guarda resultados de dieciseisavos (fase actual)
  for(const m of MATCHES){
    const h=document.getElementById('rh-'+m.id), a=document.getElementById('ra-'+m.id);
    if(h&&a&&h.value!==''&&a.value!=='') results[m.id]={h:parseInt(h.value),a:parseInt(a.value)};
  }
  await fbSet('results',results);

  // Guarda/corrige resultados de fase de grupos si la sección estaba abierta y editada
  let oldChanged = false;
  for(const m of OLD_MATCHES){
    const h=document.getElementById('orh-'+m.id), a=document.getElementById('ora-'+m.id);
    if(h&&a&&h.value!==''&&a.value!==''){
      const newVal = {h:parseInt(h.value),a:parseInt(a.value)};
      if(!oldResultsCache[m.id] || oldResultsCache[m.id].h!==newVal.h || oldResultsCache[m.id].a!==newVal.a){
        oldChanged = true;
      }
      oldResultsCache[m.id] = newVal;
    }
  }
  if(oldChanged){
    await fbSet('results_fase_grupos', oldResultsCache);
    // Recalcula el snapshot de puntos históricos de fase de grupos para todos
    const partsBackup = await fbGet('participants_fase_grupos') || {};
    const newSnapshot = {};
    for(const name of Object.keys(partsBackup)){
      newSnapshot[name] = calcOldPts(partsBackup[name] || {}, oldResultsCache);
    }
    await fbSet('group_stage_points', newSnapshot);
    groupStagePts = newSnapshot;
  }

  allParticipants=await fbGet('participants')||{};
  renderAdminPanel(); renderRanking();
  document.querySelectorAll('.savebtn').forEach(b=>{b.textContent='✓ Guardado y recalculado';setTimeout(()=>b.textContent='Guardar todo →',2200);});
}

function showMsg(id,type,text){const el=document.getElementById(id);if(el){el.className='msg '+type;el.textContent=text;}}
window.addEventListener('beforeunload',e=>{if(dirty){e.preventDefault();e.returnValue='';}});
init();
</script>
</body>
</html>
