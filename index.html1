<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>Polla Mundial 2026 🏆</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
<style>
:root{--accent:#FF4500;--accent-dim:#FF450018;--accent-mid:#FF450055;--accent2:#FFA500;--gold:#FFD700;--bg:#0F0A08;--bg2:#1A0F0A;--bg3:#261510;--text:#FFF5F0;--text2:#B89080;--text3:#7A5545;--border:#3D1F10;--red:#FF2020;--r:10px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;min-height:100vh}
.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 16px;display:flex;align-items:center;justify-content:space-between;height:52px;position:sticky;top:0;z-index:100}
.logo{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;color:var(--accent)}
.logo span{color:var(--text2);font-size:14px;margin-left:6px}
.upill{background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:4px 12px;font-size:12px;font-weight:600;cursor:pointer;color:var(--text2);display:flex;align-items:center;gap:6px}
.dot{width:7px;height:7px;border-radius:50%;background:var(--text3)}
.tabs{display:flex;background:var(--bg2);border-bottom:1px solid var(--border);overflow-x:auto}
.tab{flex:1;min-width:72px;padding:12px 6px;font-size:11px;font-weight:600;color:var(--text3);cursor:pointer;border:none;background:none;text-transform:uppercase;letter-spacing:.7px;border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s}
.tab:hover{color:var(--text2)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.panel{display:none;padding:16px;max-width:700px;margin:0 auto;padding-bottom:80px}
.panel.active{display:block}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:18px}
.card h2{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;margin-bottom:6px}
.card p{font-size:13px;color:var(--text2);margin-bottom:16px;line-height:1.5}
.field{margin-bottom:12px}
.field label{display:block;font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px}
.field input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 14px;font-size:14px;color:var(--text);outline:none;transition:border .2s}
.field input:focus{border-color:var(--accent)}
.btn-p{width:100%;background:var(--accent);border:none;border-radius:8px;padding:12px;font-size:14px;font-weight:700;color:#000;cursor:pointer;transition:opacity .2s;margin-top:4px}
.btn-p:hover{opacity:.85}
.btn-s{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 16px;font-size:13px;font-weight:600;color:var(--text2);cursor:pointer;transition:all .2s;width:100%;margin-top:8px}
.btn-s:hover{border-color:var(--accent);color:var(--accent)}
.msg{font-size:12px;padding:8px 12px;border-radius:6px;margin-top:8px}
.msg.ok{background:#8B5CF615;color:var(--accent);border:1px solid var(--accent-mid)}
.msg.err{background:#E8404015;color:var(--red);border:1px solid #E8404055}
.save-float{position:fixed;bottom:16px;right:16px;background:var(--accent);border:none;border-radius:28px;padding:12px 22px;font-size:13px;font-weight:700;color:#000;cursor:pointer;z-index:200;box-shadow:0 4px 20px #8B5CF650;display:none}
.g-hdr{display:flex;align-items:center;gap:10px;margin:18px 0 7px}
.g-lbl{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;color:var(--accent)}
.g-line{flex:1;height:1px;background:var(--border)}
.mc{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:9px 11px;margin-bottom:5px;transition:border .2s}
.mc.filled{border-color:#1E3D30}
.mc.exact{border-color:var(--accent);background:#8B5CF608}
.mc.winner{border-color:var(--gold);background:#F5C84208}
.mc.loserpts{border-color:var(--accent2);background:#4A9EFF08}
.mc.locked .si{opacity:.35;pointer-events:none;cursor:not-allowed}
.mi{display:grid;grid-template-columns:1fr 36px 14px 36px 1fr;align-items:center;gap:5px}
.tn{font-size:11px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tn.h{text-align:right}.tn.a{text-align:left}
.si{width:36px;height:30px;text-align:center;font-size:14px;font-weight:700;background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text);outline:none;-moz-appearance:textfield}
.si::-webkit-outer-spin-button,.si::-webkit-inner-spin-button{-webkit-appearance:none}
.si:focus{border-color:var(--accent)}
.vs{font-size:11px;color:var(--text3);text-align:center;font-weight:700}
.mm{font-size:10px;color:var(--text3);text-align:center;margin-top:4px}
.mm.ex{color:var(--accent);font-weight:600}
.mm.win{color:var(--gold);font-weight:600}
.mm.loser{color:var(--accent2);font-weight:600}
.mm.closed{color:var(--red)}
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px}
.sbox{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:12px;text-align:center}
.sbox .n{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--accent)}
.sbox .l{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;margin-top:2px}
.rtable{width:100%;border-collapse:collapse}
.rtable th{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;padding:7px 8px;border-bottom:1px solid var(--border);text-align:left}
.rtable td{padding:10px 8px;border-bottom:1px solid var(--border);font-size:13px}
.rtable tr:last-child td{border-bottom:none}
.rtable tr.me td{background:var(--accent-dim)}
.pts{font-family:'Bebas Neue',sans-serif;font-size:28px;color:#FFA500;text-align:right;text-shadow:0 0 14px #FFA50066}
.lupd{font-size:11px;color:var(--text3);text-align:right;margin-bottom:10px;display:flex;justify-content:flex-end;align-items:center;gap:8px}
.rbtn{background:none;border:1px solid var(--border);border-radius:6px;padding:4px 10px;font-size:11px;color:var(--text3);cursor:pointer}
.rbtn:hover{border-color:var(--accent);color:var(--accent)}
.ahdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px}
.ag{font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--gold);letter-spacing:1px;margin:12px 0 4px}
.phase-hdr{display:flex;justify-content:space-between;align-items:center;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:11px 14px;cursor:pointer;font-size:13px;font-weight:600;color:var(--text);user-select:none}
.phase-hdr:hover{border-color:var(--accent-mid)}
.phase-hdr .chev{color:var(--text3);font-size:12px}
.am{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:8px 11px;margin-bottom:4px}
.am.done{border-color:#2A3A20}
.ami{display:grid;grid-template-columns:1fr 36px 12px 36px 1fr;align-items:center;gap:5px}
.ai{width:36px;height:30px;text-align:center;font-size:14px;font-weight:700;background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text);outline:none;-moz-appearance:textfield}
.ai::-webkit-outer-spin-button,.ai::-webkit-inner-spin-button{-webkit-appearance:none}
.ai:focus{border-color:var(--gold)}
.savebtn{background:var(--gold);border:none;border-radius:8px;padding:10px 20px;font-size:13px;font-weight:700;color:#000;cursor:pointer}
.banner{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 13px;margin-bottom:14px;font-size:12px;color:var(--text2);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.banner span{color:var(--gold);font-weight:600}
.prog-wrap{background:var(--bg3);border-radius:8px;height:5px;overflow:hidden;margin:8px 0 14px}
.prog-bar{height:5px;background:var(--accent);border-radius:8px;transition:width .4s}
.ev-match{background:var(--bg2);border:1px solid var(--accent-mid);border-radius:var(--r);padding:14px;margin-bottom:16px}
.ev-teams{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;text-align:center;color:var(--text);margin-bottom:4px}
.ev-date{font-size:11px;color:var(--text3);text-align:center;margin-bottom:12px}
.ev-result{font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--accent);text-align:center;margin-bottom:12px;letter-spacing:2px}
.ev-table{width:100%;border-collapse:collapse;font-size:13px}
.ev-table th{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;padding:7px 8px;border-bottom:1px solid var(--border);text-align:left}
.ev-table td{padding:9px 8px;border-bottom:1px solid var(--border)}
.ev-table tr:last-child td{border-bottom:none}
.ev-score{font-weight:700;font-size:15px;text-align:center}
.ev-score.exact{color:var(--accent)}
.ev-score.winner{color:var(--gold)}
.ev-score.loser{color:var(--accent2)}
.ev-score.wrong{color:var(--text3)}
.ev-score.pending{color:var(--text2)}
.ev-nav{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.ev-nav button{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:7px 14px;font-size:12px;font-weight:600;color:var(--text2);cursor:pointer}
.ev-nav button:hover{border-color:var(--accent);color:var(--accent)}
.ev-nav button.active{border-color:var(--accent);color:var(--accent);background:var(--accent-dim)}
</style>
</head>
<body>
<div class="header">
  <div class="logo">Mundial 2026 <span>OCTAVOS</span></div>
  <div class="upill" id="upill" onclick="logoutUser()">
    <span class="dot" id="udot"></span>
    <span id="uname">Entrar</span>
  </div>
</div>
<div class="tabs">
  <button class="tab active" onclick="goTab('inicio')">Inicio</button>
  <button class="tab" onclick="goTab('fixture')">Pronósticos</button>
  <button class="tab" onclick="goTab('envivo')">⚽ En Vivo</button>
  <button class="tab" onclick="goTab('ranking')">Clasificación</button>
  <button class="tab" onclick="goTab('admin')">Admin</button>
</div>
<button class="save-float" id="sfloat" onclick="saveAll()">💾 Guardar</button>
<div class="panel active" id="p-inicio"><div id="reg"></div></div>
<div class="panel" id="p-fixture"><div id="fix"></div></div>
<div class="panel" id="p-envivo"><div id="envivo"></div></div>
<div class="panel" id="p-ranking"><div id="rank"></div></div>
<div class="panel" id="p-admin"><div id="adm"></div></div>

